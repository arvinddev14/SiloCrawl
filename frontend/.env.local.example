# Frontend environment (copy to .env.local for local dev; set the same keys in
# the Vercel dashboard for production).

# Public URL of the SiloCrawl backend API.
#   local dev:   http://localhost:8000
#   production:  your Render URL, e.g. https://silocrawl-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Only needed if the backend has AUTH_ENABLED=true. Must match one of API_KEYS.
# NEXT_PUBLIC_API_KEY=
