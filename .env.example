# --- LLM (open-source, via a HuggingFace Inference Endpoint) ---
# Get a token at https://huggingface.co/settings/tokens
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_ENDPOINT_URL=https://api-inference.huggingface.co/models/openai/gpt-oss-120b/v1/
EXTRACT_MODEL=openai/gpt-oss-120b

# --- Queue (crawl jobs) ---
REDIS_URL=redis://localhost:6379

# --- Crawler behaviour ---
# SSRF guard: outbound fetches refuse private/loopback/link-local destinations.
# Only set true to deliberately scrape hosts on your own internal network.
ALLOW_PRIVATE_NETWORKS=false
FETCH_MAX_BYTES=10000000
RESPECT_ROBOTS=true
CRAWL_MAX_PAGES=100
CRAWL_CONCURRENCY=5
PER_DOMAIN_DELAY=1.0

# --- Optional: cache scrape responses in Redis (seconds; 0 = off) ---
SCRAPE_CACHE_TTL=0

# --- Observability ---
LOG_LEVEL=INFO
TELEMETRY_ENABLED=true

# --- Optional: API-key auth (off by default; self-hosting needs no keys) ---
AUTH_ENABLED=false
API_KEYS=
RATE_LIMIT_PER_MINUTE=60
